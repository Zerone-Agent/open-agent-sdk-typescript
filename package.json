{
  "name": "@zerone-agent/open-agent-sdk",
  "author": {
    "name": "Zerone",
    "url": "https://github.com/Zerone-Agent"
  },
  "homepage": "https://github.com/Zerone-Agent/open-agent-sdk",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zerone-Agent/open-agent-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Zerone-Agent/open-agent-sdk/issues"
  },
  "version": "0.1.7",
  "description": "Open-source Agent SDK. Runs the full agent loop in-process — no local CLI required. Deploy anywhere: cloud, serverless, Docker, CI/CD.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const p=require('path');(function walk(dir){for(const f of fs.readdirSync(dir)){const fp=p.join(dir,f);fs.statSync(fp).isDirectory()?walk(fp):f.endsWith('.txt')&&fs.copyFileSync(fp,p.join('dist',p.relative('src',fp)))}})('src/tools')\"",
    "dev": "tsc --watch",
    "test": "npx tsx examples/01-simple-query.ts",
    "test:all": "for f in examples/*.ts; do echo \"--- Running $f ---\"; npx tsx $f; echo; done",
    "web": "npx tsx examples/web/server.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "cross-spawn": "^7.0.6",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  },
  "keywords": [
    "open-agent-sdk",
    "zerone",
    "agent",
    "sdk",
    "ai",
    "llm",
    "tools",
    "agentic",
    "coding-agent",
    "mcp"
  ],
  "license": "MIT"
}
